rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return firestore.get(/databases/(default)/documents/users/$(uid));
    }

    function isAdmin() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.role == 'admin'
        && userDoc(request.auth.uid).data.status == 'active';
    }

    match /payment_proofs/{fileName} {
      allow read: if isAdmin()
        || (signedIn() && fileName == request.auth.uid + '.jpg');
      allow write: if signedIn() && fileName == request.auth.uid + '.jpg';
    }
  }
}
